# ============================================================
# 灵析 (Lingxi) 项目 .gitignore 配置
# ============================================================

# ----------------------------------------
# 依赖
# ----------------------------------------
node_modules/
.pnp
.pnp.js

# ----------------------------------------
# 测试
# ----------------------------------------
coverage/

# ----------------------------------------
# Next.js
# ----------------------------------------
.next/
out/

# ----------------------------------------
# 生产构建
# ----------------------------------------
build/
dist/

# ----------------------------------------
# 杂项
# ----------------------------------------
.DS_Store
*.pem

# ----------------------------------------
# 调试日志
# ----------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------
# 本地环境变量
# ----------------------------------------
.env
.env*.local

# ----------------------------------------
# Vercel
# ----------------------------------------
.vercel

# ----------------------------------------
# TypeScript
# ----------------------------------------
*.tsbuildinfo
next-env.d.ts

# ----------------------------------------
# IDE / 编辑器
# ----------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ----------------------------------------
# 操作系统
# ----------------------------------------
Thumbs.db

# ----------------------------------------
# 日志
# ----------------------------------------
*.log

# ----------------------------------------
# 数据库
# ----------------------------------------
*.db
*.db-journal

# ----------------------------------------
# 用户上传
# ----------------------------------------
public/avatars/
public/lingxi-logo.png

# ----------------------------------------
# 脚本临时文件
# ----------------------------------------
.zscripts/

# ----------------------------------------
# Python
# ----------------------------------------
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# ----------------------------------------
# Prisma (生成的客户端已在 node_modules 中)
# ----------------------------------------
node_modules/.prisma/

# ----------------------------------------
# 包管理器锁文件 (根据团队统一工具保留需要的)
# ----------------------------------------
# yarn.lock
# pnpm-lock.yaml
# bun.lockb

# ----------------------------------------
# 后端
# ----------------------------------------
backend/*.db
backend/*.db-journal
backend/__pycache__/

# ----------------------------------------
# 数据导入工具 (tools/)
# ----------------------------------------
tools/__pycache__/

# ----------------------------------------
# 模型文件 (原始目录被忽略，使用 model.zip 分发)
# ----------------------------------------
backend/models/multilingual-e5-small/